    "@vueuse/core": "^14.3.0",
    "@wangeditor/editor": "^5.1.23",
    "@wangeditor/editor-for-vue": "^5.1.12",
    "axios": "^1.18.1",
    "dayjs": "^1.11.21",
    "driver.js": "^1.6.0",
    "echarts": "^6.1.0",
    "element-plus": "^2.14.3",
    "georaster": "^1.6.0",
    "georaster-layer-for-leaflet": "^4.1.2",
    "geotiff": "^3.0.5",
    "leaflet": "^1.9.4",
    "mitt": "^3.0.1",
    "nprogress": "^0.2.0",
    "pinia": "^3.0.4",
    "pinia-plugin-persistedstate": "^4.7.1",
    "qs": "^6.15.3",
    "screenfull": "^6.0.2",
    "sortablejs": "^1.15.7",
    "three": "^0.185.1",
    "vue": "^3.5.39",
    "vue-i18n": "^11.4.6",
    "vue-router": "^5.1.0",
    "vuedraggable": "^4.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@stylistic/eslint-plugin": "^5.10.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^24.10.1",
    "@types/nprogress": "^0.2.3",
    "@types/qs": "^6.15.1",
    "@types/sortablejs": "^1.15.9",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vitejs/plugin-vue-jsx": "^5.1.6",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.2",
    "code-inspector-plugin": "^1.3.0",
    "cz-git": "1.13.1",
    "czg": "^1.13.1",
    "eslint": "10.7.0",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-vue": "10.9.2",
    "fast-glob": "^3.3.3",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "sass": "^1.101.0",
    "typescript": "~6.0.3",
    "typescript-eslint": "8.63.0",
    "vite": "npm:rolldown-vite@7.3.1",
    "vite-plugin-svg-icons": "^2.0.1",
    "vue-eslint-parser": "10.3.0",
    "vue-tsc": "^3.3.7"
  },
  "pnpm": {
    "overrides": {
      "vite": "npm:rolldown-vite@7.3.1"
