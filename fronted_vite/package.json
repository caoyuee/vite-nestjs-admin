{
  "name": "fronted_vite",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "preinstall": "node ../scripts/check-pnpm.js",
    "dev": "pnpm check && vite",
    "build": "pnpm check && vite build",
    "preview": "vite preview",
    "type-check": "vue-tsc -b",
    "check": "pnpm type-check && pnpm lint:check",
    "lint": "eslint . --fix",
    "lint:check": "eslint .",
    "format": "prettier --write \"src/**/*.{vue,ts,tsx,js,jsx,json,scss,css,md}\" \"*.{ts,js,json,md}\"",
    "format:check": "prettier --check \"src/**/*.{vue,ts,tsx,js,jsx,json,scss,css,md}\" \"*.{ts,js,json,md}\""
  },
  "dependencies": {
    "@echarts-x/custom-liquid-fill": "1.0.2",
