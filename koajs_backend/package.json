{
  "name": "koajs-backend",
  "version": "1.0.0",
  "description": "",
  "main": "./dist/index.mjs",
  "exports": "./dist/index.mjs",
  "type": "module",
  "scripts": {
    "preinstall": "node ../scripts/check-pnpm.js",
    "build": "pkgroll",
    "start": "node ./dist/index.mjs",
    "dev": "tsx watch src/index.ts",
    "dev:debug": "tsx --inspect-brk src/index.ts",
    "type-check": "tsc --noEmit src/index.ts",
    "lint": "eslint 'src/**/*.{ts,js}' --ext .ts",
    "lint:fix": "eslint 'src/**/*.{ts,js}' --ext .ts --fix",
    "format": "prettier --write .",
    "lint-staged": "lint-staged",
    "prepare": "husky install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.20.0",
  "dependencies": {
    "@koa/router": "^15.1.0",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dayjs": "^1.11.19",
    "dotenv": "^17.2.3",
    "ioredis": "^5.8.2",
    "jsonwebtoken": "^9.0.3",
    "koa": "^3.1.1",
    "koa-body": "^7.0.0",
    "koa-jwt": "^4.0.4",
    "koa-static": "^5.0.0",
    "koa2-swagger-ui": "^5.12.0",
    "mysql2": "^3.15.3",
    "reflect-metadata": "^0.2.2",
    "typeorm": "^0.3.28",
    "winston": "^3.19.0",
    "winston-daily-rotate-file": "^5.0.0",
    "yamljs": "^0.3.0"
  },
  "lint-staged": {
    "src/**/*.{ts,js,json,md}": [
      "pnpm run lint:fix",
      "pnpm run format",
      "git add"
    ]
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.10",
    "@types/koa": "^3.0.1",
    "@types/koa-static": "^4.0.4",
    "@types/yamljs": "^0.2.34",
    "pkgroll": "^2.21.4",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "eslint": "^10.0.3",
    "@typescript-eslint/parser": "^8.57.0",
    "@typescript-eslint/eslint-plugin": "^8.57.0",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.1",
    "lint-staged": "^16.3.3",
    "husky": "^9.1.7",
    "@commitlint/config-conventional": "^20.4.4",
    "@commitlint/cli": "^20.4.4",
    "semantic-release": "^25.0.3"
  }
}
