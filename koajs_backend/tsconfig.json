{
  // TypeScript 编译配置文件（tsconfig），以下为本项目使用的配置及中文说明。
  // 说明：此文件使用 JSONC，可包含注释。保留原有配置值，仅替换注释为中文以便团队阅读。

  "compilerOptions": {
    // 文件布局相关：
    // rootDir：源代码根目录（TypeScript 源文件位置）
    "rootDir": "./src",
    // outDir：编译后输出目录（如生成 JS、声明文件等）
    "outDir": "./dist",
    // noEmit：是否禁止输出编译产物（true 表示仅做类型检查，不生成文件）
    "noEmit": true,
    // allowImportingTsExtensions：是否允许在 import 路径中写入 .ts 扩展名
    "allowImportingTsExtensions": true,

    // 运行环境与模块系统配置：
    // module：模块语法目标（例如 commonjs、esnext、nodenext），决定编译输出的模块格式
    "module": "nodenext",
    // target：编译后代码的 ECMAScript 版本目标（决定语法与内置 API 的兼容性）
    "target": "esnext",
    // types：全局类型声明包（空数组表示默认不引入额外全局类型）
    "types": [],
    // lib：可根据需要启用内置环境声明（如 "esnext"、"dom" 等），此处注释示例
    // "lib": ["esnext"],

    // 其他输出相关：
    // sourceMap：是否生成 source map，便于调试 TypeScript 原始源码
    "sourceMap": true,
    // declaration：是否生成 .d.ts 类型声明文件（对外发布包时常用）
    "declaration": true,
    // declarationMap：是否生成声明文件对应的 source map
    "declarationMap": true,
    // 更严格的类型检查选项：
    // noUncheckedIndexedAccess：对通过索引访问的属性启用更严格的 undefined 检查
    "noUncheckedIndexedAccess": true,
    // "exactOptionalPropertyTypes": true, // 可选：开启后可更精确地处理可选属性类型

    // 装饰器与元数据（用于 TypeORM、依赖注入等场景）：
    // emitDecoratorMetadata：配合 reflect-metadata 使用，输出装饰器的类型元数据
    "emitDecoratorMetadata": true,
    // experimentalDecorators：启用实验性的装饰器语法支持
    "experimentalDecorators": true,

    "moduleResolution": "nodenext",
    // strictNullChecks：是否启用严格的 null/undefined 检查（本项目设置为 false）
    "strictNullChecks": false,

    // 代码风格/质量相关（可选项，通常根据团队偏好开启或关闭）：
    // "noImplicitReturns": true, // 要求函数的所有分支必须有返回值
    // "noImplicitOverride": true, // 要求子类覆盖方法时显式标注 override
    "noUnusedLocals": true, // 报告未使用的局部变量
    "noUnusedParameters": true, // 报告未使用的函数参数
    // "noFallthroughCasesInSwitch": true, // 报告 switch case 穿透
    // "noPropertyAccessFromIndexSignature": true, // 防止通过索引访问未声明的属性
    "useUnknownInCatchVariables": true, // 在 catch 语句中使用 unknown 类型而非 any
    "noImplicitAny": true, // 禁止隐式的 any 类型

    // 推荐的严格模式与模块/编译行为：
    // strict：开启一组严格类型检查（建议保持 true 以获得更严谨的类型保障）
    "strict": true,
    // verbatimModuleSyntax：保留模块语法原样，影响与 Babel 等工具链的互操作
    "verbatimModuleSyntax": true,
    // isolatedModules：每个文件作为独立模块编译（与 babel 配合时通常需要）
    "isolatedModules": true,
    // noUncheckedSideEffectImports：检测导入时的副作用，避免被忽略
    "noUncheckedSideEffectImports": true,
    // moduleDetection：模块检测策略（force 表示强制按模块解析）
    "moduleDetection": "force",
    // resolveJsonModule：允许导入 JSON 文件作为模块
    "resolveJsonModule": true,
    // allowJs：允许编译 JS 文件（如果项目中包含 JS 代码）
    "allowJs": true,
    // esModuleInterop：启用与 CommonJS 模块的互操作性支持
    "esModuleInterop": true,
    // skipLibCheck：跳过第三方声明文件类型检查，可以加快构建，但可能掩盖类型问题
    "skipLibCheck": true,
    // noEmitHelpers：是否禁止生成辅助函数（如 __extends 等），通常与外部运行时库配合使用
    "noEmitHelpers": false,
    // noEmitOnError：在有类型错误时阻止输出编译产物
    "noEmitOnError": true
  },

  // include：指定参与类型检查/编译的文件 glob 列表
  "include": ["src/**/**.ts"],

  // exclude：排除文件/目录不参与编译（如 node_modules）
  "exclude": ["./node_modules", "dist"]
}
